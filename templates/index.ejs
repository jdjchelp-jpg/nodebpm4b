<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - BPM4B
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
        rel="stylesheet">
    <style>
        :root {
            /* Premium v9 Dashboard Palette (Dark Default) */
            --bg-page: #020617;
            --bg-sidebar: #0f172a;
            --bg-card: #1e293b;
            --bg-card-hover: #334155;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --primary: #6366f1;
            --primary-glow: rgba(99, 102, 241, 0.4);
            --accent: #8b5cf6;
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
            --border: rgba(255, 255, 255, 0.08);
            --border-hover: rgba(255, 255, 255, 0.15);
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 20px;
            --radius-xl: 32px;
            --font-main: 'Outfit', sans-serif;
            --font-body: 'Inter', sans-serif;
            --sidebar-width: 280px;
        }

        [data-theme="light"] {
            --bg-page: #f8fafc;
            --bg-sidebar: #ffffff;
            --bg-card: #ffffff;
            --bg-card-hover: #f1f5f9;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --border: rgba(0, 0, 0, 0.06);
            --border-hover: rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-page);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            transition: background-color 0.3s ease;
        }

        /* Layout Structure */
        .app-shell {
            display: flex;
            width: 100%;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Styling */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 2rem 1.5rem;
            z-index: 50;
        }

        .main-content {
            flex: 1;
            overflow-y: auto;
            position: relative;
            padding: 2.5rem;
            background-image:
                radial-gradient(circle at 0% 0%, rgba(99, 102, 241, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 100% 100%, rgba(139, 92, 246, 0.05) 0%, transparent 40%);
        }

        /* Brand section */
        .brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 3rem;
        }

        .brand-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px var(--primary-glow);
        }

        .brand h1 {
            font-family: var(--font-main);
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.025em;
        }

        /* Navigation */
        .nav-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin-bottom: 2rem;
        }

        .nav-label {
            font-family: var(--font-main);
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            padding-left: 0.5rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-radius: var(--radius-md);
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9375rem;
            transition: all 0.2s ease;
            cursor: pointer;
            border: 1px solid transparent;
        }

        .nav-item:hover {
            color: var(--text-primary);
            background: var(--bg-card-hover);
        }

        .nav-item.active {
            color: var(--primary);
            background: rgba(99, 102, 241, 0.1);
            border-color: rgba(99, 102, 241, 0.2);
        }

        .nav-item svg {
            width: 20px;
            height: 20px;
            opacity: 0.7;
        }

        .nav-item.active svg {
            opacity: 1;
            stroke: var(--primary);
        }

        /* Version & Theme switch at bottom */
        .sidebar-footer {
            margin-top: auto;
            border-top: 1px solid var(--border);
            padding-top: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .version-tag {
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .theme-toggle-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-secondary);
        }

        /* Bento Dashboard Grid */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            grid-auto-rows: minmax(120px, auto);
            gap: 1.5rem;
            max-width: 1440px;
            margin: 0 auto;
        }

        .bento-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.75rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .bento-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-4px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        /* Span Helpers */
        .col-span-full {
            grid-column: span 12;
        }

        .col-span-8 {
            grid-column: span 8;
        }

        .col-span-4 {
            grid-column: span 4;
        }

        .col-span-6 {
            grid-column: span 6;
        }

        .row-span-2 {
            grid-row: span 2;
        }

        .row-span-3 {
            grid-row: span 3;
        }

        @media (max-width: 1024px) {

            .col-span-8,
            .col-span-4,
            .col-span-6 {
                grid-column: span 12;
            }
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .card-title {
            font-family: var(--font-main);
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 0.875rem;
        }

        .card-icon-sm {
            width: 36px;
            height: 36px;
            background: rgba(99, 102, 241, 0.1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
        }

        /* Tool views */
        .tool-content {
            display: none;
            animation: fadeIn 0.5s ease-out;
        }

        .tool-content.active {
            display: block;
        }

        /* Inputs & Controls */
        .input-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            margin-bottom: 0.625rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .form-select,
        .form-input,
        textarea {
            width: 100%;
            background: var(--bg-sidebar);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 0.875rem 1.125rem;
            color: var(--text-primary);
            font-family: var(--font-body);
            font-size: 0.9375rem;
            transition: all 0.2s ease;
        }

        .form-select:focus,
        .form-input:focus,
        textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
        }

        textarea {
            min-height: 120px;
            resize: vertical;
        }

        /* Drop Zone */
        .drop-zone {
            border: 2px dashed var(--border);
            border-radius: var(--radius-lg);
            padding: 3.5rem 2rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
            background: rgba(255, 255, 255, 0.015);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .drop-zone:hover,
        .drop-zone.drag-over {
            border-color: var(--primary);
            background: rgba(99, 102, 241, 0.04);
            transform: scale(1.005);
        }

        .drop-zone-icon {
            width: 48px;
            height: 48px;
            color: var(--primary);
            opacity: 0.9;
        }

        .drop-zone p {
            font-weight: 600;
            font-size: 1rem;
        }

        .drop-zone span {
            font-size: 0.8125rem;
            color: var(--text-muted);
        }

        .active-file-indicator {
            margin-top: 1.5rem;
            padding: 1rem 1.25rem;
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.2);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.875rem;
            color: var(--success);
            font-weight: 600;
        }

        /* Engine Status Widget */
        .engine-status-card {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .status-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .status-indicator {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 0.375rem 0.875rem;
            border-radius: 999px;
        }

        .status-ready {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .status-loading {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
        }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            padding: 1rem 1.5rem;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 0.9375rem;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
            width: 100%;
            font-family: var(--font-main);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: white;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.45);
        }

        .btn-secondary {
            background: var(--bg-card-hover);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        /* Progress Display */
        .progress-card {
            margin-top: auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .progress-bar-container {
            height: 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(to right, var(--primary), var(--accent));
            width: 0%;
            transition: width 0.4s ease-out;
            position: relative;
        }

        .progress-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            animation: shimmer 1.5s infinite;
        }

        /* Log view */
        .log-vessel {
            background: rgba(0, 0, 0, 0.25);
            border-radius: var(--radius-md);
            padding: 1rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-muted);
            height: 150px;
            overflow-y: auto;
            border: 1px solid var(--border);
        }

        .log-line {
            margin-bottom: 0.25rem;
            border-left: 2px solid transparent;
            padding-left: 0.5rem;
        }

        .log-line.info {
            border-color: var(--primary);
        }

        .log-line.success {
            border-color: var(--success);
            color: var(--text-primary);
        }

        /* Chapter Preview Grid */
        .chapter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
            max-height: 400px;
            overflow-y: auto;
            padding-right: 0.5rem;
        }

        .chapter-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 1rem;
            transition: all 0.2s ease;
        }

        .chapter-card:hover {
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.04);
        }

        .chapter-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .chapter-badge {
            background: var(--primary);
            color: white;
            padding: 0.15rem 0.5rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 800;
        }

        .chapter-name {
            font-weight: 700;
            font-size: 0.875rem;
        }

        /* Quick Entry Styles */
        .quick-entry-bar {
            display: grid;
            grid-template-columns: 1fr 1fr auto;
            gap: 1rem;
            padding: 1.25rem;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid var(--border);
            align-items: center;
            animation: fadeIn 0.3s ease;
        }

        .quick-entry-bar.hidden {
            display: none;
        }

        .entry-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .next-mark {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
            background: rgba(0, 0, 0, 0.2);
            padding: 0.25rem 0.6rem;
            border-radius: 4px;
        }

        .remove-ch {
            opacity: 0;
            transition: opacity 0.2s;
            color: var(--error);
            cursor: pointer;
            padding: 4px;
        }

        .chapter-card:hover .remove-ch {
            opacity: 1;
        }

        @keyframes shimmer {
            from {
                transform: translateX(-100%);
            }

            to {
                transform: translateX(100%);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.6;
            }

            100% {
                opacity: 1;
            }
        }

        /* Toast notifications */
        .toast-container {
            position: fixed;
            top: 2rem;
            right: 2rem;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .toast {
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 1.25rem 2rem;
            border-radius: var(--radius-md);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 1rem;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <div class="toast-container" id="toastContainer"></div>

    <div class="app-shell">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                        <path d="M9 18V5l12-2v13M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm12-3a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                    </svg>
                </div>
                <h1>AudioBPM</h1>
            </div>

            <div class="nav-group">
                <div class="nav-label">Tools</div>
                <a class="nav-item active" data-tool="conversion">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2v20M2 12h20" />
                    </svg>
                    MP3 Conversion
                </a>
                <a class="nav-item" data-tool="audiobook">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path
                            d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5V4.5z" />
                    </svg>
                    Audiobook Gen
                </a>
                <a class="nav-item" data-tool="aax">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                    AAX Converter
                </a>
            </div>

            <div class="nav-group">
                <div class="nav-label">System</div>
                <div class="engine-status">
                    <div class="status-indicator ready" id="engineStatusDot"></div>
                    <div style="flex: 1">
                        <div style="font-size: 0.75rem; font-weight: 700; color: var(--text-primary)">Kokoro Local</div>
                        <div style="font-size: 0.65rem; color: var(--text-muted)" id="engineStatusText">Core Ready</div>
                    </div>
                </div>
            </div>

            <div class="sidebar-footer">
                <div class="theme-toggle-container">
                    <span>Dark Appearance</span>
                    <label class="toggle-switch">
                        <input type="checkbox" id="themeToggle" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="version-tag">
                    <span>Engine v<%= version %></span>
                    <span>Stable</span>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- MP3 Conversion Panel -->
            <div class="bento-card col-span-8 tool-content active" id="conversionPanel">
                <div class="card-header">
                    <h3 class="card-title">
                        <div class="card-icon-sm">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M12 2v20M2 12h20" />
                            </svg>
                        </div>
                        MP3 to M4B Pipeline
                    </h3>
                </div>

                <div class="input-group">
                    <label>Source Audio</label>
                    <div class="drop-zone" id="mp3DropZone">
                        <svg class="drop-zone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" />
                        </svg>
                        <p>Drop MP3 or M3U8 here</p>
                        <span>Up to 2GB supported</span>
                        <input type="file" id="sourceFile" class="hidden" accept=".mp3,.m3u8">
                    </div>
                    <div id="mp3FileInfo" class="active-file-indicator hidden"></div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label>Output Filename</label>
                        <input type="text" id="outputName" class="form-input" placeholder="my-audiobook.m4b">
                    </div>
                    <div class="input-group">
                        <label>Audio Fidelity</label>
                        <select id="audioQuality" class="form-select">
                            <option value="copy">Stream Copy (Original)</option>
                            <option value="libmp3lame">Standard (128k)</option>
                            <option value="aac" selected>High Fidelity (256k AAC)</option>
                        </select>
                    </div>
                </div>

                <button id="convertBtn" class="btn btn-primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                    Initialize Conversion
                </button>
            </div>

            <!-- Audiobook Generator Panel (Document) -->
            <div class="bento-card col-span-8 tool-content" id="audiobookPanel">
                <div class="card-header">
                    <h3 class="card-title">
                        <div class="card-icon-sm">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path
                                    d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5V4.5z" />
                            </svg>
                        </div>
                        Document to Audiobook
                    </h3>
                </div>

                <div class="input-group">
                    <label>E-Book or Document</label>
                    <div class="drop-zone" id="docDropZone">
                        <svg class="drop-zone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                        </svg>
                        <p>Upload PDF, EPUB, or DOCX</p>
                        <span>Local Kokoro processing</span>
                        <input type="file" id="docFile" class="hidden" accept=".pdf,.epub,.docx,.txt">
                    </div>
                    <div id="docFileInfo" class="active-file-indicator hidden"></div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label>Voice Model</label>
                        <select id="ttsVoice" class="form-select">
                            <option value="af_heart">Female (Heart)</option>
                            <option value="af_bella">Female (Bella)</option>
                            <option value="am_adam">Male (Adam)</option>
                            <option value="am_michael">Male (Michael)</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Speed</label>
                        <select id="ttsSpeed" class="form-select">
                            <option value="0.8">0.8x</option>
                            <option value="1.0" selected>1.0x (Natural)</option>
                            <option value="1.2">1.2x</option>
                            <option value="1.5">1.5x</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Language</label>
                        <select id="ttsLanguage" class="form-select">
                            <option value="en-us">English (US)</option>
                            <option value="en-gb">English (GB)</option>
                        </select>
                    </div>
                </div>

                <div class="chapter-actions mt-3">
                    <button id="previewChaptersBtn" class="btn btn-secondary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        Analyze Chapters
                    </button>
                    <button id="generateAudiobookBtn" class="btn btn-primary">
                        Generate Audiobook
                    </button>
                </div>
            </div>

            <!-- AAX Converter Panel -->
            <div class="bento-card col-span-8 tool-content" id="aaxPanel">
                <div class="card-header">
                    <h3 class="card-title">
                        <div class="card-icon-sm">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </div>
                        AAX Decryptor
                    </h3>
                </div>

                <div class="input-group">
                    <label>Audible File</label>
                    <div class="drop-zone" id="aaxDropZone">
                        <svg class="drop-zone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                        <p>Select AAX or AA File</p>
                        <input type="file" id="aaxFile" class="hidden" accept=".aax,.aa">
                    </div>
                    <div id="aaxFileInfo" class="active-file-indicator hidden"></div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label>Activation Bytes</label>
                        <input type="text" id="activationBytes" class="form-input" placeholder="8 characters (hex)">
                    </div>
                    <div class="input-group">
                        <label>Export Format</label>
                        <select id="aaxOutputFormat" class="form-select">
                            <option value="m4b">M4B (Lossless)</option>
                            <option value="mp3">MP3</option>
                        </select>
                    </div>
                </div>

                <button id="convertAaxBtn" class="btn btn-primary">Decrypt and Convert</button>
            </div>

            <!-- Sidebar/Right Column Bento Cards -->
            <div class="bento-card col-span-4 row-span-2">
                <div class="card-header">
                    <h3 class="card-title">Metadata & Status</h3>
                </div>

                <div class="progress-card">
                    <div class="stat-card">
                        <div class="stat-value" id="progressPercent">0%</div>
                        <div class="stat-label">Pipeline Progress</div>
                    </div>
                    <div class="progress-bar-container">
                        <div class="progress-fill" id="progressBar"></div>
                    </div>
                    <div id="statusText" style="font-size: 0.8125rem; color: var(--text-muted);">Awaiting
                        initialization...</div>
                </div>

                <div class="log-vessel mt-3" id="processLog">
                    <!-- Logs will appear here -->
                    <div class="log-line info">V9 System Ready.</div>
                </div>
            </div>

            <!-- Preview Grid Card -->
            <div class="bento-card col-span-12 tool-content active" id="chapterPreviewPanel">
                <div class="card-header">
                    <h3 class="card-title">Chapter Manifest</h3>
                    <div class="chapter-actions">
                        <button class="btn btn-sm btn-secondary" id="addChapterBtn">Add Mark</button>
                        <button class="btn btn-sm btn-secondary" id="clearChaptersBtn">Clear All</button>
                    </div>
                </div>

                <div class="chapter-grid" id="chaptersContainer">
                    <!-- Chapters will be rendered here as cards -->
                </div>

                <div id="quickEntryBar" class="quick-entry-bar hidden">
                    <div class="input-group" style="margin: 0;">
                        <input type="text" id="chapterTitle" class="form-input" placeholder="Chapter Title">
                    </div>
                    <div class="input-group" style="margin: 0;">
                        <input type="text" id="chapterDuration" class="form-input"
                            placeholder="Duration (min or MM:SS)">
                    </div>
                    <div class="entry-actions">
                        <div class="next-mark">Starts: <span id="nextTimestamp">00:00:00</span></div>
                        <button class="btn btn-primary btn-sm" id="confirmAddChapterBtn">Add</button>
                    </div>
                </div>
            </div>

    </div>
    </main>
    </div>
    </div>

    <script>
        // Premium v9 Orchestration Logic
        const state = {
            activeTool: 'conversion',
            chapters: [],
            cumulativeTime: 0,
            isProcessing: false,
            theme: 'dark'
        };

        const elements = {
            navItems: document.querySelectorAll('.nav-item'),
            toolPanels: document.querySelectorAll('.tool-content'),
            progressBar: document.getElementById('progressBar'),
            progressPercent: document.getElementById('progressPercent'),
            statusText: document.getElementById('statusText'),
            processLog: document.getElementById('processLog'),
            engineStatusDot: document.getElementById('engineStatusDot'),
            engineStatusText: document.getElementById('engineStatusText'),
            toastContainer: document.getElementById('toastContainer'),
            chaptersContainer: document.getElementById('chaptersContainer'),
            themeToggle: document.getElementById('themeToggle'),
            quickEntryBar: document.getElementById('quickEntryBar'),
            chapterTitle: document.getElementById('chapterTitle'),
            chapterDuration: document.getElementById('chapterDuration'),
            confirmAddChapterBtn: document.getElementById('confirmAddChapterBtn'),
            nextTimestamp: document.getElementById('nextTimestamp'),
            addChapterBtn: document.getElementById('addChapterBtn')
        };

        const config = {
            version: '<%= version %>'
        };

        // --- Core Functions ---

        function init() {
            setupNavigation();
            setupTheme();
            setupDropZones();
            setupChapterBuilder();
            checkEngineHealth();
            log('V9 Pipeline Initialized', 'info');
        }

        function setupNavigation() {
            elements.navItems.forEach(item => {
                item.addEventListener('click', () => {
                    const tool = item.dataset.tool;
                    switchTool(tool);
                });
            });
        }

        function switchTool(toolId) {
            state.activeTool = toolId;

            elements.navItems.forEach(nav => {
                nav.classList.toggle('active', nav.dataset.tool === toolId);
            });

            elements.toolPanels.forEach(panel => {
                const isMatch = panel.id === (toolId + 'Panel');
                panel.classList.toggle('active', isMatch);

                // Manifest visibility logic
                if (panel.id === 'chapterPreviewPanel') {
                    panel.classList.add('active'); // Keep manifest visible for most tools
                }
            });

            // Special handling for panels that don't need manifest
            const noManifestTools = ['aax'];
            document.getElementById('chapterPreviewPanel').classList.toggle('hidden', noManifestTools.includes(toolId));

            log(`Switched to ${toolId} pipeline`, 'info');
        }

        function setupTheme() {
            const savedTheme = localStorage.getItem('theme') || 'dark';
            applyTheme(savedTheme);
            elements.themeToggle.checked = savedTheme === 'dark';

            elements.themeToggle.addEventListener('change', (e) => {
                const newTheme = e.target.checked ? 'dark' : 'light';
                applyTheme(newTheme);
            });
        }

        function applyTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
            state.theme = theme;
        }

        function setupDropZones() {
            ['mp3', 'doc', 'aax'].forEach(id => {
                const dz = document.getElementById(`${id}DropZone`);
                const input = document.getElementById(id === 'mp3' ? 'sourceFile' : `${id}File`);
                const info = document.getElementById(`${id}FileInfo`);

                if (!dz || !input) return;

                dz.addEventListener('click', () => input.click());

                dz.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    dz.classList.add('drag-over');
                });

                dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));

                dz.addEventListener('drop', (e) => {
                    e.preventDefault();
                    dz.classList.remove('drag-over');
                    if (e.dataTransfer.files.length > 0) {
                        handleFileSelect(id, e.dataTransfer.files[0]);
                    }
                });

                input.addEventListener('change', (e) => {
                    if (e.target.files.length > 0) {
                        handleFileSelect(id, e.target.files[0]);
                    }
                });
            });
        }

        function handleFileSelect(id, file) {
            const info = document.getElementById(`${id}FileInfo`);
            info.innerHTML = `
            <div class="file-badge">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" /><polyline points="13 2 13 9 20 9" /></svg>
                <span>${file.name}</span>
                <small>${(file.size / (1024 * 1024)).toFixed(1)}MB</small>
            </div>
            `;
            info.classList.remove('hidden');
            log(`Loaded: ${file.name}`, 'success');

            if (id === 'doc') {
                document.getElementById('audiobookPanel').querySelectorAll('input, select').forEach(el => {
                    if (el.id === 'audiobookOutputName' || el.id === 'outputName') {
                        el.value = file.name.split('.')[0] + '.m4b';
                    }
                });
            }
        }

        function setupChapterBuilder() {
            elements.addChapterBtn.addEventListener('click', () => {
                elements.quickEntryBar.classList.toggle('hidden');
                if (!elements.quickEntryBar.classList.contains('hidden')) {
                    elements.chapterTitle.focus();
                }
            });

            elements.confirmAddChapterBtn.addEventListener('click', () => {
                const title = elements.chapterTitle.value.trim();
                const durationRaw = elements.chapterDuration.value.trim();

                if (!title) return showToast('Enter chapter title', 'error');

                const durationSec = parseDuration(durationRaw);
                if (durationSec === null || durationSec <= 0) {
                    return showToast('Invalid or zero duration', 'error');
                }

                addChapterMark(title, durationSec);

                // Reset and update next
                elements.chapterTitle.value = '';
                elements.chapterDuration.value = '';
                elements.nextTimestamp.textContent = formatTime(state.cumulativeTime);
            });

            elements.chapterDuration.addEventListener('input', (e) => {
                const dur = parseDuration(e.target.value);
                if (dur !== null) {
                    elements.nextTimestamp.textContent = formatTime(state.cumulativeTime + dur);
                } else {
                    elements.nextTimestamp.textContent = formatTime(state.cumulativeTime);
                }
            });

            document.getElementById('clearChaptersBtn').addEventListener('click', () => {
                if (confirm('Are you sure you want to clear all chapters?')) {
                    state.chapters = [];
                    state.cumulativeTime = 0;
                    renderManifest();
                    showToast('Manifest cleared', 'info');
                    elements.nextTimestamp.textContent = '00:00:00';
                }
            });

            window.addChapterMark = (title, durationSec) => {
                const chapter = {
                    id: Date.now(),
                    title: title || `Chapter ${state.chapters.length + 1}`,
                    duration: durationSec,
                    startTime: state.cumulativeTime
                };
                state.chapters.push(chapter);
                state.cumulativeTime += durationSec;
                renderManifest();
                showToast(`Added ${chapter.title}`, 'success');
            };
        }

        function parseDuration(input) {
            if (!input) return null;
            // Support formats like HH:MM:SS.mmm, MM:SS.mmm, SS.mmm
            if (input.includes(':') || input.includes('.')) {
                let parts = input.split(':').map(p => p.trim());
                let totalSeconds = 0;

                // Handle MM:SS or HH:MM:SS
                if (parts.length === 3) {
                    totalSeconds += parseFloat(parts[0]) * 3600; // hours
                    totalSeconds += parseFloat(parts[1]) * 60;   // minutes
                    totalSeconds += parseFloat(parts[2]);        // seconds + ms
                } else if (parts.length === 2) {
                    totalSeconds += parseFloat(parts[0]) * 60;   // minutes
                    totalSeconds += parseFloat(parts[1]);        // seconds + ms
                } else if (parts.length === 1 && input.includes('.')) {
                    totalSeconds += parseFloat(parts[0]);        // just seconds + ms
                }

                return isNaN(totalSeconds) ? null : totalSeconds;
            }

            const num = parseFloat(input);
            return isNaN(num) ? null : num * 60; // Default to minutes if just a number
        }

        function removeChapter(id) {
            const idx = state.chapters.findIndex(c => c.id === id);
            if (idx === -1) return;

            state.chapters.splice(idx, 1);
            // Re-calculate all subsequent start times
            state.cumulativeTime = 0;
            state.chapters = state.chapters.map(ch => {
                const updated = { ...ch, startTime: state.cumulativeTime };
                state.cumulativeTime += ch.duration;
                return updated;
            });

            renderManifest();
            showToast('Chapter removed', 'info');
            elements.nextTimestamp.textContent = formatTime(state.cumulativeTime);
        }

        function renderManifest() {
            elements.chaptersContainer.innerHTML = state.chapters.map((ch, idx) => `
                <div class="chapter-card">
                    <div class="chapter-header">
                        <div class="chapter-badge">#${idx + 1}</div>
                        <div class="chapter-name">${ch.title}</div>
                        <div style="flex:1"></div>
                        <div class="remove-ch" onclick="removeChapter(${ch.id})">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6L6 18M6 6l12 12"/></svg>
                        </div>
                    </div>
                    <div class="chapter-meta">${formatTime(ch.startTime)} • ${formatTime(ch.duration)}</div>
                </div>
            `).join('');

            if (state.chapters.length === 0) {
                elements.chaptersContainer.innerHTML = '<div class="empty-state">No manifest data detected</div>';
            }
        }

        async function checkEngineHealth() {
            try {
                const res = await fetch('/api/health');
                const data = await res.json();
                if (data.status === 'ok') {
                    elements.engineStatusDot.className = 'status-indicator ready';
                    const engineName = data.engine || 'Kokoro Local';
                    elements.engineStatusText.textContent = engineName + ' Ready';
                }
            } catch (e) {
                elements.engineStatusDot.className = 'status-indicator error';
                elements.engineStatusText.textContent = 'Engine Offline';
            }
        }

        // --- Utility Functions ---

        function formatTime(seconds) {
            const h = Math.floor(seconds / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = Math.floor(seconds % 60);
            const ms = Math.floor((seconds % 1) * 1000);

            let res = `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
            if (ms > 0) {
                res += `.${ms.toString().padStart(3, '0')}`;
            }
            return res;
        }

        function log(msg, type = 'info') {
            const line = document.createElement('div');
            line.className = `log-line ${type}`;
            const time = new Date().toLocaleTimeString([], { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
            line.innerHTML = `<span class="log-time">[${time}]</span> ${msg}`;
            elements.processLog.prepend(line);

            // Limit log lines
            if (elements.processLog.children.length > 50) {
                elements.processLog.removeChild(elements.processLog.lastChild);
            }
        }

        function showToast(msg, type = 'info') {
            log(msg, type);
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.textContent = msg;
            elements.toastContainer.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }

        // --- Pipeline Execution ---

        document.getElementById('convertBtn').addEventListener('click', async () => {
            const fileInput = document.getElementById('sourceFile');
            if (!fileInput.files.length) return showToast('Select source file', 'error');

            startPipeline();
            const formData = new FormData();
            formData.append('source_file', fileInput.files[0]);
            formData.append('output_name', document.getElementById('outputName').value);
            formData.append('audio_quality', document.getElementById('audioQuality').value);

            try {
                const res = await fetch('/api/convert', { method: 'POST', body: formData });
                if (!res.ok) throw new Error('Pipeline failed');
                downloadBlob(await res.blob(), document.getElementById('outputName').value || 'audiobook.m4b');
                finishPipeline('Conversion Complete');
            } catch (e) {
                failPipeline(e.message);
            }
        });

        document.getElementById('generateAudiobookBtn').addEventListener('click', async () => {
            const fileInput = document.getElementById('docFile');
            if (!fileInput.files.length) return showToast('Select document', 'error');

            startPipeline();
            log('Initializing Kokoro Local TTS...', 'info');

            const formData = new FormData();
            formData.append('document_file', fileInput.files[0]);
            formData.append('voice', document.getElementById('ttsVoice').value);
            formData.append('speed', document.getElementById('ttsSpeed').value);
            formData.append('language', document.getElementById('ttsLanguage').value);

            try {
                const res = await fetch('/api/document-to-audiobook', { method: 'POST', body: formData });
                if (!res.ok) throw new Error('TTS Generation failed');
                downloadBlob(await res.blob(), 'audiobook.m4b');
                finishPipeline('Audiobook Generated');
            } catch (e) {
                failPipeline(e.message);
            }
        });

        document.getElementById('previewChaptersBtn').addEventListener('click', async () => {
            const fileInput = document.getElementById('docFile');
            if (!fileInput.files.length) return showToast('Select document', 'error');

            log('Scanning document structure...', 'info');
            const formData = new FormData();
            formData.append('document_file', fileInput.files[0]);

            try {
                const res = await fetch('/api/preview-chapters', { method: 'POST', body: formData });
                const data = await res.json();

                state.chapters = data.chapters.map(c => ({
                    title: c.title,
                    duration: 0, // Duration unknown until TTS
                    startTime: 0
                }));
                renderManifest();
                showToast(`Detected ${data.chapters.length} chapters`, 'success');
            } catch (e) {
                log('Analysis failed', 'error');
            }
        });

        function startPipeline() {
            state.isProcessing = true;
            elements.progressBar.style.width = '10%';
            elements.progressPercent.textContent = '10%';
            elements.statusText.textContent = 'Processing Pipeline...';

            // Simulate progress for better UX
            let p = 10;
            const iv = setInterval(() => {
                if (p < 85 && state.isProcessing) {
                    p += Math.random() * 5;
                    elements.progressBar.style.width = `${p}%`;
                    elements.progressPercent.textContent = `${Math.round(p)}%`;
                } else {
                    clearInterval(iv);
                }
            }, 1000);
        }

        function finishPipeline(msg) {
            state.isProcessing = false;
            elements.progressBar.style.width = '100%';
            elements.progressPercent.textContent = '100%';
            elements.statusText.textContent = msg;
            showToast(msg, 'success');
        }

        function failPipeline(err) {
            state.isProcessing = false;
            elements.progressBar.style.width = '0%';
            elements.statusText.textContent = 'Pipeline Error';
            showToast(err, 'error');
        }

        function downloadBlob(blob, name) {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = name;
            a.click();
            URL.revokeObjectURL(url);
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>

</html>